<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.neobank.controller.DashboardController" prefWidth="1280" prefHeight="720" style="-fx-background-color: #F8F9FA;">
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <VBox alignment="CENTER" prefHeight="90" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="⬢ NeoBank" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                <Label fx:id="lblUsuarioMenu" text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
            </VBox>
            <Region prefHeight="10"/>
            <Button text="📊  Dashboard" onAction="#irDashboard" prefWidth="240" prefHeight="50" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 30; -fx-cursor: hand; -fx-border-color: #1D52A8; -fx-border-width: 0 0 0 4;"/>
            <Button text="👥  Clientes" onAction="#irClientes" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🏦  Cuentas" onAction="#irCuentas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💰  Movimientos" onAction="#irMovimientos" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🔁  Transferencias" onAction="#irTransferencias" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💳  Tarjetas" onAction="#irTarjetas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" onAction="#cerrarSesion" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #E53935; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #F8F9FA; -fx-background-color: #F8F9FA; -fx-border-color: transparent;">
            <content>
                <VBox spacing="25" style="-fx-padding: 35;">
                    <Label text="Resumen General" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                    <HBox spacing="20">
                        <VBox prefWidth="220" prefHeight="110" alignment="CENTER" spacing="5" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 20;">
                            <Label fx:id="lblTotalClientes" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                            <Label text="Total Clientes" style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        </VBox>
                        <VBox prefWidth="220" prefHeight="110" alignment="CENTER" spacing="5" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 20;">
                            <Label fx:id="lblTotalCuentas" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                            <Label text="Total Cuentas" style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        </VBox>
                        <VBox prefWidth="220" prefHeight="110" alignment="CENTER" spacing="5" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 20;">
                            <Label fx:id="lblDineroTotal" text="S/ 0.00" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #43A047;"/>
                            <Label text="Dinero Total" style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        </VBox>
                        <VBox prefWidth="220" prefHeight="110" alignment="CENTER" spacing="5" style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 20;">
                            <Label fx:id="lblTransferenciasHoy" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E53935;"/>
                            <Label text="Transferencias Hoy" style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        </VBox>
                    </HBox>
                    <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 25;">
                        <Label text="Actividad del Sistema" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A; -fx-padding: 0 0 15 0;"/>
                        <BarChart fx:id="barChart" prefHeight="300" style="-fx-background-color: transparent;">
                            <xAxis><CategoryAxis style="-fx-tick-label-fill: #666666;"/></xAxis>
                            <yAxis><NumberAxis style="-fx-tick-label-fill: #666666;"/></yAxis>
                        </BarChart>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>