<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #F4F6F8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.neobank.controller.DashboardController">
    <children>
        <VBox prefHeight="720.0" prefWidth="250.0" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent #EAEAEA transparent transparent;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" prefHeight="130.0" spacing="8.0">
                    <children>
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;" text="⬢ NeoBank" />
                        <Label fx:id="lblUsuarioMenu" style="-fx-font-size: 12px; -fx-text-fill: #7F8C8D;" text="Usuario | ROL" />
                    </children>
                    <padding>
                        <Insets top="20.0" />
                    </padding>
                </VBox>

                <Region prefHeight="10.0" />

                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button mnemonicParsing="false" onAction="#irDashboard" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: BASELINE_LEFT; -fx-border-color: transparent transparent transparent #1D52A8; -fx-border-width: 0 0 0 4; -fx-padding: 0 0 0 20;" text="📊 Dashboard" />

                        <Button mnemonicParsing="false" onAction="#irClientes" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15px; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="👥 Clientes" />
                        <Button mnemonicParsing="false" onAction="#irCuentas" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15px; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="💳 Cuentas" />
                        <Button mnemonicParsing="false" onAction="#irMovimientos" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15px; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="💵 Movimientos" />
                        <Button mnemonicParsing="false" onAction="#irTransferencias" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15px; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="🔄 Transferencias" />
                        <Button mnemonicParsing="false" onAction="#irTarjetas" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 15px; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="💳 Tarjetas" />

                        <Region prefHeight="15.0" />

                        <Button mnemonicParsing="false" onAction="#irHistorial" prefHeight="45.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #3949AB; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24;" text="🛡️ Auditoría Global" />
                    </children>
                </VBox>

                <Button mnemonicParsing="false" onAction="#cerrarSesion" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: transparent; -fx-text-fill: #E53935; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: BASELINE_LEFT; -fx-padding: 0 0 0 24; -fx-border-color: #EAEAEA transparent transparent transparent;" text="🚪 Cerrar Sesión" />
            </children>
        </VBox>

        <VBox layoutX="250.0" prefHeight="720.0" prefWidth="1030.0" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;" text="Resumen General" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D;" text="Métricas operativas del sistema en tiempo real." />
                    </children>
                </VBox>

                <HBox spacing="20.0">
                    <children>
                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="230.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #EAEAEA; -fx-border-radius: 8;">
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="TOTAL CLIENTES" />
                                <Label fx:id="lblTotalClientes" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;" text="0" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="230.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #EAEAEA; -fx-border-radius: 8;">
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="CUENTAS ACTIVAS" />
                                <Label fx:id="lblTotalCuentas" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #43A047;" text="0" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="230.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #EAEAEA; -fx-border-radius: 8;">
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="MOVIMIENTOS" />
                                <Label fx:id="lblTransferenciasHoy" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F39C12;" text="0" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="250.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #EAEAEA; -fx-border-radius: 8;">
                            <children>
                                <Label style="-fx-font-size: 13px; -fx-text-fill: #7F8C8D; -fx-font-weight: bold;" text="CAPITAL EN BANCO" />
                                <Label fx:id="lblDineroTotal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #8E44AD;" text="S/ 0.00" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox prefHeight="400.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #EAEAEA; -fx-border-radius: 8; -fx-padding: 25;">
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;" text="Volumen del Sistema" />
                        <BarChart fx:id="barChart" prefHeight="350.0" prefWidth="900.0">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" tickLabelFill="#7f8c8d" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis side="LEFT" tickLabelFill="#7f8c8d" />
                            </yAxis>
                        </BarChart>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>