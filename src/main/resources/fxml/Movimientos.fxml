<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.neobank.controller.MovimientosController" prefWidth="1280" prefHeight="720" style="-fx-background-color: #F8F9FA;">
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <VBox alignment="CENTER" prefHeight="90" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="⬢ NeoBank" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                <Label fx:id="lblUsuarioMenu" text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
            </VBox>
            <Region prefHeight="10"/>
            <Button fx:id="btnMenuDashboard" text="📊  Dashboard" onAction="#irDashboard" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="👥  Clientes" onAction="#irClientes" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🏦  Cuentas" onAction="#irCuentas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💰  Movimientos" onAction="#irMovimientos" prefWidth="240" prefHeight="50" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 30; -fx-cursor: hand; -fx-border-color: #1D52A8; -fx-border-width: 0 0 0 4;"/>
            <Button text="🔁  Transferencias" onAction="#irTransferencias" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💳  Tarjetas" onAction="#irTarjetas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" onAction="#cerrarSesion" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #E53935; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="20" style="-fx-padding: 35;">
            <Label text="Movimientos de Cuenta" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <ComboBox fx:id="cmbCuentasBusqueda" promptText="Selecciona una cuenta..." prefWidth="350" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 4; -fx-font-size: 14px;"/>
                <Button text="Ver Movimientos" onAction="#buscarMovimientos" prefHeight="40" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblSaldoActual" text="Saldo Actual: S/ 0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
            </HBox>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Nuevo Movimiento" onAction="#nuevoMovimiento" prefHeight="40" style="-fx-background-color: #1D52A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Label fx:id="lblMensaje" text="" style="-fx-font-size: 14px; -fx-text-fill: #43A047;"/>
            </HBox>
            <TableView fx:id="tablaMovimientos" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colFecha" text="Fecha y Hora" prefWidth="150"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                    <TableColumn fx:id="colMonto" text="Monto" prefWidth="120"/>
                    <TableColumn fx:id="colDesc" text="Descripción" prefWidth="300"/>
                </columns>
            </TableView>
        </VBox>
    </center>
    <right>
        <VBox fx:id="panelFormulario" prefWidth="320" spacing="15" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1; -fx-padding: 30;" visible="false" managed="false">
            <Label text="Registrar Movimiento" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            <Region prefHeight="10"/>
            <VBox spacing="5">
                <Label text="Tipo de Movimiento *" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cmbTipoMovimiento" prefWidth="300" promptText="Seleccionar..." style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Monto (S/) *" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <TextField fx:id="txtMonto" promptText="Ej: 100.50" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-font-size: 14px; -fx-text-fill: #1A1A1A;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Descripción" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <TextField fx:id="txtDescripcion" promptText="Ej: Pago de servicios" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 8; -fx-font-size: 14px; -fx-text-fill: #1A1A1A;"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="10">
                <Button text="Confirmar" onAction="#guardarMovimiento" prefWidth="300" prefHeight="45" style="-fx-background-color: #1D52A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button text="Cancelar" onAction="#cancelarForm" prefWidth="300" prefHeight="45" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </right>
</BorderPane>