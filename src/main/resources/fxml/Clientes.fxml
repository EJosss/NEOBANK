<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="com.neobank.controller.ClientesController"
        prefWidth="1280" prefHeight="720"
        style="-fx-background-color: #1a1a2e;">

    <left>
        <VBox prefWidth="220"
              style="-fx-background-color: #16213e;">
            <VBox alignment="CENTER" prefHeight="80"
                  style="-fx-background-color: #0f3460; -fx-padding: 15;">
                <Label text="🏦 NeoBank"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4fc3f7;"/>
                <Label fx:id="lblUsuarioMenu" text="Usuario"
                       style="-fx-font-size: 11px; -fx-text-fill: #90a4ae;"/>
            </VBox>
            <Button text="📊  Dashboard" onAction="#irDashboard"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #90a4ae; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Button text="👥  Clientes" onAction="#irClientes"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: #4fc3f7; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Button text="🏦  Cuentas" onAction="#irCuentas"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #90a4ae; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Button text="💰  Movimientos" onAction="#irMovimientos"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #90a4ae; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Button text="🔁  Transferencias" onAction="#irTransferencias"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #90a4ae; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Button text="💳  Tarjetas" onAction="#irTarjetas"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #90a4ae; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" onAction="#cerrarSesion"
                    prefWidth="220" prefHeight="50"
                    style="-fx-background-color: transparent; -fx-text-fill: #ef5350; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 25; -fx-background-radius: 0; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15" style="-fx-padding: 25;">

            <!-- Título -->
            <Label text="👥 Gestión de Clientes"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <!-- Barra de búsqueda y botón -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar"
                           promptText="🔍 Buscar por nombre o DNI..."
                           prefWidth="350" prefHeight="38"
                           style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
                <Button text="🔍 Buscar" onAction="#buscarCliente"
                        prefHeight="38"
                        style="-fx-background-color: #4fc3f7; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15 0 15;"/>
                <Button text="↺ Mostrar todos" onAction="#mostrarTodos"
                        prefHeight="38"
                        style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15 0 15;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ Nuevo Cliente" onAction="#nuevoCliente"
                        prefHeight="38"
                        style="-fx-background-color: #66bb6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 15 0 15;"/>
            </HBox>

            <!-- Tabla -->
            <TableView fx:id="tablaClientes"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
                    <TableColumn fx:id="colDni" text="DNI" prefWidth="120"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120"/>
                    <TableColumn fx:id="colCorreo" text="Correo" prefWidth="200"/>
                    <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="200"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Botones de acción -->
            <HBox spacing="10">
                <Button text="✏ Editar" onAction="#editarCliente"
                        prefHeight="38"
                        style="-fx-background-color: #ffd54f; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Button text="🗑 Eliminar" onAction="#eliminarCliente"
                        prefHeight="38"
                        style="-fx-background-color: #ef5350; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Label fx:id="lblMensaje" text=""
                       style="-fx-text-fill: #66bb6a; -fx-font-size: 13px;"/>
            </HBox>

        </VBox>
    </center>

    <!-- FORMULARIO (panel derecho oculto) -->
    <right>
        <VBox fx:id="panelFormulario"
              prefWidth="320" spacing="12"
              style="-fx-background-color: #16213e; -fx-padding: 25;"
              visible="false" managed="false">

            <Label fx:id="lblTituloForm" text="Nuevo Cliente"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Label text="Nombre *" style="-fx-text-fill: #90a4ae; -fx-font-size: 12px;"/>
            <TextField fx:id="txtNombre" promptText="Nombre completo"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 10;"/>

            <Label text="DNI *" style="-fx-text-fill: #90a4ae; -fx-font-size: 12px;"/>
            <TextField fx:id="txtDni" promptText="Número de DNI"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 10;"/>

            <Label text="Teléfono" style="-fx-text-fill: #90a4ae; -fx-font-size: 12px;"/>
            <TextField fx:id="txtTelefono" promptText="Número de teléfono"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 10;"/>

            <Label text="Correo" style="-fx-text-fill: #90a4ae; -fx-font-size: 12px;"/>
            <TextField fx:id="txtCorreo" promptText="Correo electrónico"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 10;"/>

            <Label text="Dirección" style="-fx-text-fill: #90a4ae; -fx-font-size: 12px;"/>
            <TextField fx:id="txtDireccion" promptText="Dirección"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-prompt-text-fill: #546e7a; -fx-background-radius: 8; -fx-padding: 10;"/>

            <Label fx:id="lblErrorForm" text=""
                   style="-fx-text-fill: #ef5350; -fx-font-size: 12px;"/>

            <HBox spacing="10">
                <Button text="💾 Guardar" onAction="#guardarCliente"
                        prefWidth="130" prefHeight="40"
                        style="-fx-background-color: #4fc3f7; -fx-text-fill: #1a1a2e; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button text="✕ Cancelar" onAction="#cancelarForm"
                        prefWidth="130" prefHeight="40"
                        style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>