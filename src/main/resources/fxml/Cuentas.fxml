<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.neobank.controller.CuentasController" stylesheets="@../css/style.css">

    <left>
        <VBox styleClass="sidebar" spacing="15" prefWidth="250">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>
            <Label text="NEOBANK" styleClass="sidebar-title"/>
            <Label fx:id="lblUsuarioMenu" styleClass="sidebar-user"/>
            <Separator/>
            <Button text="Dashboard" onAction="#irDashboard" styleClass="btn-menu" maxWidth="Infinity"/>
            <Button text="Clientes" onAction="#irClientes" styleClass="btn-menu" maxWidth="Infinity"/>
            <Button text="Cuentas" styleClass="btn-menu, btn-menu-active" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Cerrar Sesión" onAction="#cerrarSesion" styleClass="btn-logout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

            <Label text="Gestión de Cuentas" styleClass="page-title"/>

            <HBox spacing="10">
                <Button text="➕ Nueva Cuenta" onAction="#nuevaCuenta" styleClass="btn-primary"/>
                <Label fx:id="lblMensaje" text="" />
            </HBox>

            <VBox fx:id="panelFormulario" spacing="10" visible="false" managed="false" style="-fx-border-color: #ccc; -fx-padding: 15; -fx-border-radius: 5;">
                <Label text="Crear Nueva Cuenta" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbCliente" promptText="Seleccionar Cliente" prefWidth="300"/>
                <ComboBox fx:id="cbTipoCuenta" promptText="Tipo de Cuenta" prefWidth="300"/>
                <TextField fx:id="txtSaldoInicial" promptText="Saldo Inicial (ej. 1000.00)" prefWidth="300"/>
                <HBox spacing="10">
                    <Button text="Guardar" onAction="#guardarCuenta" styleClass="btn-success"/>
                    <Button text="Cancelar" onAction="#cancelarForm" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <TableView fx:id="tablaCuentas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNumero" text="Nº Cuenta" prefWidth="150"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150"/>
                    <TableColumn fx:id="colSaldo" text="Saldo" prefWidth="150"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>