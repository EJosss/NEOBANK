<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.neobank.controller.TarjetasController" prefWidth="1280" prefHeight="720" style="-fx-background-color: #F8F9FA;">
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <VBox alignment="CENTER" prefHeight="90" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="⬢ NeoBank" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                <Label fx:id="lblUsuarioMenu" text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
            </VBox>
            <Region prefHeight="10"/>
            <Button fx:id="btnMenuDashboard" text="📊  Dashboard" onAction="#irDashboard" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="👥  Clientes" onAction="#irClientes" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🏦  Cuentas" onAction="#irCuentas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💰  Movimientos" onAction="#irMovimientos" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🔁  Transferencias" onAction="#irTransferencias" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💳  Tarjetas" prefWidth="240" prefHeight="50" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 30; -fx-cursor: hand; -fx-border-color: #1D52A8; -fx-border-width: 0 0 0 4;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" onAction="#cerrarSesion" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #E53935; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="20" style="-fx-padding: 35;">
            <Label text="Gestión de Tarjetas" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Emitir Nueva Tarjeta" onAction="#nuevaTarjeta" prefHeight="40" style="-fx-background-color: #1D52A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Button fx:id="btnBloquear" text="Bloquear Tarjeta" onAction="#bloquearTarjeta" prefHeight="40" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblMensaje" text="" style="-fx-font-size: 14px; -fx-text-fill: #43A047;"/>
            </HBox>
            <TableView fx:id="tablaTarjetas" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colNumero" text="Número de Tarjeta" prefWidth="200"/>
                    <TableColumn fx:id="colCuenta" text="Cuenta Vinculada" prefWidth="180"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                    <TableColumn fx:id="colVencimiento" text="Vencimiento" prefWidth="120"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
    <right>
        <VBox fx:id="panelFormulario" prefWidth="320" spacing="15" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 0 1; -fx-padding: 30;" visible="false" managed="false">
            <Label text="Emitir Tarjeta" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            <Region prefHeight="10"/>
            <VBox spacing="5">
                <Label text="Cuenta a vincular *" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cmbCuentas" prefWidth="300" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #CCCCCC transparent; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Tipo de Tarjeta *" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cmbTipo" prefWidth="300" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #CCCCCC transparent; -fx-border-width: 0 0 1 0; -fx-padding: 5 0;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Límite (Solo Crédito)" style="-fx-text-fill: #888888; -fx-font-size: 12px;"/>
                <TextField fx:id="txtLimite" promptText="Ej: 5000" style="-fx-background-color: transparent; -fx-border-color: transparent transparent #CCCCCC transparent; -fx-border-width: 0 0 1 0; -fx-padding: 5 0 5 0; -fx-font-size: 14px; -fx-text-fill: #1A1A1A;"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="10">
                <Button text="Generar" onAction="#guardarTarjeta" prefWidth="300" prefHeight="45" style="-fx-background-color: #1D52A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button text="Cancelar" onAction="#cancelarForm" prefWidth="300" prefHeight="45" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </right>
</BorderPane>