<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.neobank.controller.FacturasController" prefWidth="1280" prefHeight="720" style="-fx-background-color: #F8F9FA;">
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;">
            <VBox alignment="CENTER" prefHeight="90" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                <Label text="⬢ NeoBank" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D52A8;"/>
                <Label fx:id="lblUsuarioMenu" text="Usuario" style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
            </VBox>
            <Region prefHeight="10"/>
            <Button fx:id="btnMenuDashboard" text="📊  Dashboard" onAction="#irDashboard" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="👥  Clientes" onAction="#irClientes" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🏦  Cuentas" onAction="#irCuentas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💰  Movimientos" onAction="#irMovimientos" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🔁  Transferencias" onAction="#irTransferencias" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="💳  Tarjetas" onAction="#irTarjetas" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
            <Button text="🧾  Facturas" prefWidth="240" prefHeight="50" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 30; -fx-cursor: hand; -fx-border-color: #1D52A8; -fx-border-width: 0 0 0 4;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="🚪  Cerrar Sesión" onAction="#cerrarSesion" prefWidth="240" prefHeight="50" style="-fx-background-color: transparent; -fx-text-fill: #E53935; -fx-font-size: 14px; -fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 34; -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="20" style="-fx-padding: 35;">
            <Label text="Gestión de Comprobantes Electrónicos" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Nueva Factura:" style="-fx-font-weight: bold; -fx-text-fill: #1D52A8; -fx-font-size: 14px;"/>
                <TextField fx:id="txtIdClienteForm" promptText="ID Cliente" prefWidth="100" style="-fx-padding: 8; -fx-border-radius: 4;"/>
                <TextField fx:id="txtConceptoForm" promptText="Concepto de la operación" prefWidth="250" style="-fx-padding: 8; -fx-border-radius: 4;"/>
                <TextField fx:id="txtMontoForm" promptText="Monto Base (S/)" prefWidth="120" style="-fx-padding: 8; -fx-border-radius: 4;"/>
                <Button text="➕ Emitir Comprobante" onAction="#agregarNuevaFactura" style="-fx-background-color: #1D52A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 15;"/>
            </HBox>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar" promptText="Buscar por número de factura..." prefWidth="350" prefHeight="40" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-text-fill: #1A1A1A; -fx-prompt-text-fill: #888888; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 14px;"/>
                <Button text="Limpiar Filtro" onAction="#limpiarFiltro" prefHeight="40" style="-fx-background-color: #F0F4F8; -fx-text-fill: #1D52A8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 20 0 20;"/>
                <CheckBox fx:id="chkVerAnuladas" text="Ver Facturas Anuladas" style="-fx-font-size: 14px; -fx-text-fill: #666666; -fx-cursor: hand;"/>
            </HBox>

            <TableView fx:id="tablaFacturas" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNumero" text="N° Comprobante" prefWidth="150"/>
                    <TableColumn fx:id="colCliente" text="ID Cliente" prefWidth="100"/>
                    <TableColumn fx:id="colConcepto" text="Concepto de Operación" prefWidth="280"/>
                    <TableColumn fx:id="colFecha" text="Fecha Emisión" prefWidth="160"/>
                    <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="110"/>
                    <TableColumn fx:id="colIgv" text="IGV (18%)" prefWidth="100"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="110"/>
                </columns>
            </TableView>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button fx:id="btnAnular" text="Anular Comprobante" onAction="#anularFactura" prefHeight="40" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 25 0 25;"/>
                <Button text="📋 Simular Impresión" onAction="#simularImpresion" prefHeight="40" style="-fx-background-color: #43A047; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 0 25 0 25;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>